# Supabase public browser-safe variables.
# These values are allowed to be exposed to the browser when Row Level Security is enabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Future server-only variable.
# WARNING: Never prefix this with NEXT_PUBLIC_, never import it into client code,
# and never commit a real service role key. It bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=
